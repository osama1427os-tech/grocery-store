    <style>
        .contact-container {
            max-width: 600px;
            margin: 40px auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            text-align: center;
        }
        .contact-info {
            margin-top: 25px;
            text-align: right;
            background: #f9f9f9;
            padding: 15px;
            border-radius: 6px;
            border-right: 4px solid #2ecc71;
        }
        .contact-info p {
            margin: 10px 0;
            font-size: 16px;
            color: #333;
        }
        .contact-info strong {
            color: #2ecc71;
        }
