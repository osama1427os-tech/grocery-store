<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>متجر القروشري</title>

    <link rel="stylesheet" href="/static/css/style.css">
</head>

<body>

    <header>
        <div class="container">

            <div class="header-content">

                <h1 class="logo">
                    Grocery Store
                </h1>

                <nav>
                    <a href="/">الرئيسية</a>
                    <a href="#">المتجر</a>
                    <a href="#">العروض</a>
                    <a href="#">تواصل</a>

                    <a href="#" class="cart-link">
                        السلة
                        <span class="cart-count" id="cartCount">0</span>
                    </a>
                </nav>

            </div>
        </div>
    </header>

    <main>

        <section class="hero">

            <div class="hero-overlay">

                <div class="container">

                    <div class="hero-content">

                        <h2>أفضل المنتجات الطازجة يومياً</h2>

                        <p>
                            خضروات - فواكه - مشروبات - منتجات يومية بأسعار ممتازة
                        </p>

                        <a href="#" class="hero-btn">
                            تسوق الآن
                        </a>

                    </div>

                </div>

            </div>

        </section>

        <section class="products-section">

            <div class="container">

                <h2 class="section-title">
                    المنتجات المميزة
                </h2>

                <div class="products-grid">

                    <div class="product-card">

                        <img src="https://images.unsplash.com/photo-1567306226416-28f0efdc88ce?q=80&w=1200">

                        <div class="product-info">

                            <h3>تفاح طازج</h3>

                            <p class="price">15 ريال</p>

                            <button class="add-btn">
                                إضافة للسلة
                            </button>

                        </div>

                    </div>

                    <div class="product-card">

                        <img src="https://images.unsplash.com/photo-1586201375761-83865001e31c?q=80&w=1200">

                        <div class="product-info">

                            <h3>ارز  </h3>

                            <p class="price">80 ريال</p>

                            <button class="add-btn">
                                إضافة للسلة
                            </button>

                        </div>

                    </div>

                    <div class="product-card">

                        <img src="https://images.unsplash.com/photo-1607623814075-e51df1bdc82f?q=80&w=1200">

                        <div class="product-info">

                            <h3>لحم غنم حري </h3>

                            <p class="price">120 ريال</p>

                            <button class="add-btn">
                                إضافة للسلة
                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </section>

    </main>

    <footer>

        <div class="container">

            <div class="footer-content">

                <div class="footer-section">

                    <h3>Grocery Store</h3>

                    <p>
                        متجرك الأول للمنتجات الطازجة بأفضل الأسعار
                    </p>

                </div>

                <div class="footer-section">

                    <h3>روابط سريعة</h3>

                    <ul>

                        <li>
                            <a href="/">الرئيسية</a>
                        </li>

                        <li>
                            <a href="#">المتجر</a>
                        </li>

                        <li>
                            <a href="#">العروض</a>
                        </li>

                        <li>
                            <a href="#">تواصل</a>
                        </li>

                    </ul>

                </div>

                <div class="footer-section">

                    <h3>النشرة البريدية</h3>

                    <form>

                        <input type="email"
                               placeholder="بريدك الإلكتروني"
                               required>

                        <button type="submit">
                            اشترك
                        </button>

                    </form>

                </div>

            </div>

            <div class="footer-bottom">

                <p>
                    © 2026 Grocery Store | جميع الحقوق محفوظة
                </p>

            </div>

        </div>

    </footer>

    <script src="/static/js/main.js"></script>

</body>

</html>